# Backend Environment Variables
# Copy this file to .env and fill in the values.

# LLM Inference (REQUIRED)
GROQ_API_KEY="your_groq_api_key_here"

# Database Configuration
# Default: SQLite (local file). For Render PostgreSQL, use:
# DATABASE_URL="postgresql://user:password@host:port/dbname"
DATABASE_URL="sqlite:///./careerlaunch.db"

# Frontend URL for CORS (REQUIRED for deployment)
# For multiple origins, separate with commas:
# FRONTEND_URL="https://your-app.vercel.app,http://localhost:3000"
FRONTEND_URL="http://localhost:3000"
